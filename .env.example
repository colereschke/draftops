# Copy this file to .env.local and fill in your DATABASE_URL.
# .env.local is gitignored — never commit it.

# Local (WSL2 native Postgres):
# DATABASE_URL=postgresql://draftops:draftops@localhost/draftops

# Neon (production):
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=

# Dedicated local database used only by `pnpm test:integration`.
# When omitted, the test harness derives `draftops_test` from the local DATABASE_URL.
TEST_DATABASE_URL=

# Sentry error observability. The DSN is safe to expose to the browser; the remaining
# Sentry variables are build-time secrets used only for production source-map uploads.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_RELEASE=

# Optional server-only HMAC key for stable, non-reversible user correlation in logs.
OBSERVABILITY_HASH_KEY=
